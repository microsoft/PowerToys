<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear />
        <add key="PowerToysDependencies" value="https://microsoft.pkgs.visualstudio.com/Dart/_packaging/PowerToysDependencies/nuget/v3/index.json" />
        <!-- nuget.org is scoped to the WindowsAppSDK experimental family only (see packageSourceMapping below).
             Required because Microsoft.WindowsAppSDK 2.2.2-experimental* is published on nuget.org but is not
             mirrored in PowerToysDependencies. This experimental release includes WinAppSDK PR #6376
             (MRT PRI lookup under sparse package identity). All patterns are exact-match Microsoft-signed
             packages; packageSourceMapping prevents any other package from resolving via nuget.org. -->
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    </packageSources>
    <packageSourceMapping>
        <clear />
        <packageSource key="PowerToysDependencies">
            <package pattern="*" />
        </packageSource>
        <packageSource key="nuget.org">
            <package pattern="Microsoft.WindowsAppSDK" />
            <package pattern="Microsoft.WindowsAppSDK.*" />
            <package pattern="Microsoft.Windows.AI.MachineLearning" />
        </packageSource>
    </packageSourceMapping>
    <disabledPackageSources>
        <clear />
    </disabledPackageSources>
</configuration>
