<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <?include $(sys.CURRENTDIR)\Common.wxi?>

  <?define MacroImagesFilesPath=$(var.BinDir)\Assets\Macro\?>

  <Fragment>
    <DirectoryRef Id="BaseApplicationsAssetsFolder">
      <Directory Id="MacroImagesFolder" Name="Macro" />
    </DirectoryRef>

    <ComponentGroup Id="MacroComponentGroup">
      <Component Id="RemoveMacroFolder" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890" Directory="INSTALLFOLDER">
        <RegistryKey Root="$(var.RegistryScope)" Key="Software\Classes\powertoys\components">
          <RegistryValue Type="string" Name="RemoveMacroFolder" Value="" KeyPath="yes" />
        </RegistryKey>
        <RemoveFolder Id="RemoveFolderMacroImagesFolder" Directory="MacroImagesFolder" On="uninstall" />
      </Component>
    </ComponentGroup>

  </Fragment>
</Wix>
