<?xml version="1.0" encoding="utf-8"?>
<Project>
  <!--
    spdlog consumers import this sheet to pick up the historical SPDLOG_*
    preprocessor defines so source compiles identically against the
    vcpkg-installed spdlog as it did against the in-tree submodule build.

    The vcpkg integration itself (VcpkgEnabled, VcpkgRoot, triplet, install)
    is wired globally in Cpp.Build.props so that import order relative to
    Microsoft.Cpp.targets is guaranteed (vcpkg.props must load *before* the
    C++ targets to hook into ClCompile). Many PowerToys .vcxproj files
    import deps/spdlog.props *after* Microsoft.Cpp.targets, which works fine
    for adding the SPDLOG_* defines via ItemDefinitionGroup merging, but
    would fail for vcpkg.props' include-path wiring.
  -->
  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>SPDLOG_WCHAR_TO_UTF8_SUPPORT;SPDLOG_COMPILED_LIB;SPDLOG_WCHAR_FILENAMES;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
