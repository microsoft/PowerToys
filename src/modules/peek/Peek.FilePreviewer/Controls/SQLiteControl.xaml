<UserControl
    x:Class="Peek.FilePreviewer.Controls.SqliteControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="150" MaxWidth="320" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  Left pane: table tree  -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock 
                Grid.Row="0"
                Text="{x:Bind TableCount, Mode=OneWay}" 
                FontWeight="SemiBold" 
                Margin="16,12,16,8" 
                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <TreeView
                x:Name="TableTreeView"
                Grid.Row="1"
                ItemInvoked="TableTreeView_ItemInvoked">
                <TreeView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="{Binding Content.Glyph}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="{Binding Content.Name}" TextTrimming="CharacterEllipsis">
                                <ToolTipService.ToolTip>
                                    <ToolTip Content="{Binding Content.Name}" />
                                </ToolTipService.ToolTip>
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>
        </Grid>

        <!--  Divider  -->
        <Border
            Grid.Column="1"
            Width="1"
            Background="{ThemeResource CardStrokeColorDefaultBrush}" />

        <!--  Right pane  -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Record count header  -->
            <Border
                x:Name="RecordCountHeader"
                Grid.Row="0"
                Padding="12,6"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed">
                <TextBlock x:Name="RecordCountText" />
            </Border>

            <!--  Data grid  -->
            <toolkit:DataGrid
                x:Name="TableDataGrid"
                Grid.Row="1"
                AreRowDetailsFrozen="True"
                AutoGenerateColumns="False"
                Background="Transparent"
                RowBackground="Transparent"
                AlternatingRowBackground="Transparent"
                CanDrag="False"
                ColumnWidth="Auto"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                IsReadOnly="True"
                MinColumnWidth="80"
                RowDetailsVisibilityMode="Collapsed"
                SelectionMode="Extended"
                SizeChanged="TableDataGrid_SizeChanged"
                Visibility="Collapsed">
                <toolkit:DataGrid.ColumnHeaderStyle>
                    <Style TargetType="primitives:DataGridColumnHeader">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Style>
                </toolkit:DataGrid.ColumnHeaderStyle>
            </toolkit:DataGrid>

            <!--  Placeholder when no table is selected  -->
            <StackPanel
                x:Name="NoSelectionText"
                Grid.Row="0"
                Grid.RowSpan="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">
                <FontIcon Glyph="&#xE14E;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Uid="Sqlite_NoTableSelected" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
