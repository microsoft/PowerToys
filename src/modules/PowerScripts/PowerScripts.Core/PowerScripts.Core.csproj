<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>PowerScripts.Core</RootNamespace>
    <AssemblyName>PowerScripts.Core</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <!-- The Python bootstrap ships next to the executor and any project that references Core. -->
    <None Update="Execution\_runner.py">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
