<Project Sdk="Microsoft.NET.Sdk">
  <!--
    Native WinUI 3 helper that renders the PowerScripts parameter prompt. It is a *separate* process
    from PowerScripts.Host on purpose: Keyboard Manager launches the Host hidden and actively hides
    all of the Host process's windows, so an in-process dialog would be hidden too. A child process's
    window is outside KBM's reach, so the prompt shows reliably while the Host stays silent.

    Unpackaged + self-contained Windows App SDK so it can be launched directly (no MSIX) from the
    prototype's Debug output, matching how the rest of the prototype is run.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.26100.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <RootNamespace>PowerScripts.PromptUI</RootNamespace>
    <AssemblyName>PowerScripts.PromptUI</AssemblyName>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <EnableMsixTooling>true</EnableMsixTooling>
    <Nullable>enable</Nullable>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="2.2.0" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.6901" />
  </ItemGroup>
</Project>
