{
  "schemaVersion": 1,
  "id": "py_uppercase_files",
  "name": "Uppercase File (Python)",
  "description": "Write an UPPERCASED copy of the selected text file(s) next to the original. A Python file PowerScript for the Explorer right-click menu.",
  "kind": "file",
  "runtime": "python",
  "entry": "run.py",
  "publisher": "PowerToys samples",
  "version": "1.0.0",
  "input": {
    "extensions": [".txt", ".md"],
    "minFiles": 1,
    "maxFiles": 0
  },
  "output": {
    "type": "convertedFile",
    "extension": ".UPPER.txt"
  },
  "surfaces": ["contextMenu"],
  "capabilities": ["fileRead", "fileWrite"],
  "elevation": "asInvoker"
}
