<Page
    x:Class="ImageResizer.Views.ResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:ImageResizer.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  Shared item template for error and recycle-failed results. Shows full file path with tooltip.  -->
        <DataTemplate x:Key="ResultTemplate" x:DataType="vm:ResultDisplayModel">
            <StackPanel Margin="6">
                <TextBlock
                    Margin="0,0,0,4"
                    FontWeight="SemiBold"
                    Text="{x:Bind FilePath}"
                    TextTrimming="CharacterEllipsis"
                    ToolTipService.ToolTip="{x:Bind FilePath}" />
                <TextBlock
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="{x:Bind ResultMessage}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="{StaticResource PageSectionMargin}"
            AutomationProperties.HeadingLevel="Level1"
            Style="{StaticResource SubtitleTextBlockStyle}"
            Text="{x:Bind ViewModel.HeaderText}" />

        <ScrollViewer
            Grid.Row="1"
            Padding="16,0"
            HorizontalAlignment="Stretch"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!--  Errors section  -->
                <StackPanel
                    x:Name="ErrorsSection"
                    Margin="0,8,0,8"
                    x:Load="{x:Bind ViewModel.HasErrors, Mode=OneWay}">
                    <TextBlock
                        x:Uid="Results_Errors_SectionHeader"
                        Margin="0,0,0,8"
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        TextWrapping="Wrap" />
                    <Border
                        Padding="8,4,0,4"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Errors, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <StaticResource ResourceKey="ResultTemplate" />
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!--  Warnings for when the original file could not be replaced with the resized file.  -->
                <StackPanel
                    x:Name="ReplaceWarningsSection"
                    Margin="0,8,0,8"
                    x:Load="{x:Bind ViewModel.HasReplaceWarnings, Mode=OneWay}">
                    <TextBlock
                        x:Uid="Results_ReplaceFailed_SectionHeader"
                        Margin="0,0,0,8"
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        TextWrapping="Wrap" />
                    <Border
                        Padding="8,4,0,4"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ReplaceWarnings, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ResultDisplayModel">
                                    <StackPanel Margin="6">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontWeight="SemiBold"
                                            Text="{x:Bind FilePath}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTipService.ToolTip="{x:Bind FilePath}" />
                                        <TextBlock Margin="0,0,0,4" Style="{StaticResource BodyTextBlockStyle}">
                                            <Run x:Uid="Results_ResizedAs_Label" /><Run FontWeight="SemiBold" Text="{x:Bind DestinationFileName}" />
                                        </TextBlock>
                                        <TextBlock
                                            Style="{StaticResource BodyTextBlockStyle}"
                                            Text="{x:Bind ResultMessage}"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

                <!--  Warnings for when the backup file for a replace operation could not be recycled.  -->
                <StackPanel
                    x:Name="RecycleFailedSection"
                    Margin="0,8,0,8"
                    x:Load="{x:Bind ViewModel.HasRecycleFailedWarnings, Mode=OneWay}">
                    <TextBlock
                        x:Uid="Results_RecycleFailed_SectionHeader"
                        Margin="0,0,0,8"
                        AutomationProperties.HeadingLevel="Level2"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        TextWrapping="Wrap" />
                    <Border
                        Padding="8,4,0,4"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                        <ItemsControl ItemsSource="{x:Bind ViewModel.RecycleFailedWarnings, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <StaticResource ResourceKey="ResultTemplate" />
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Margin="0,12,0,0"
            Padding="12"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button MinWidth="{StaticResource ButtonMinWidth}" Command="{x:Bind ViewModel.CloseCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Escape" />
                    </Button.KeyboardAccelerators>
                    <TextBlock x:Uid="Results_Close" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>
