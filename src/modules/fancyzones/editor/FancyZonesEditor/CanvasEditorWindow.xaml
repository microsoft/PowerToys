<local:EditorWindow
    x:Class="FancyZonesEditor.CanvasEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FancyZonesEditor"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:props="clr-namespace:FancyZonesEditor.Properties"
    Title=""
    MinWidth="420"
    AutomationProperties.Name="{x:Static props:Resources.Canvas_Layout_Editor}"
    Background="{DynamicResource LayerFillColorDefaultBrush}"
    Closed="OnClosed"
    ContentRendered="EditorWindow_ContentRendered"
    ResizeMode="NoResize"
    SizeToContent="WidthAndHeight"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="1" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Background="{DynamicResource LayerFillColorAltBrush}" FocusManager.FocusedElement="{Binding ElementName=newZoneButton}">
            <local:ClickAutomationEventButton
                x:Name="newZoneButton"
                Width="64"
                Height="64"
                Margin="0,16,0,24"
                HorizontalAlignment="Stretch"
                Click="OnAddZone"
                DataContext="{Binding Path=Model, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"
                IsEnabled="{Binding IsZoneAddingAllowed}"
                OnClickAutomationValue="{x:Static props:Resources.New_zone_added}"
                Style="{StaticResource AccentButtonStyle}"
                TabIndex="0"
                ToolTip="{x:Static props:Resources.Add_zone}">
                <TextBlock
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    FontSize="24"
                    Text="&#xE710;" />
            </local:ClickAutomationEventButton>
            <TextBlock
                Margin="16,16,16,16"
                Focusable="True"
                FontSize="12"
                TextWrapping="Wrap">
                <Run FontWeight="SemiBold" Text="{x:Static props:Resources.KeyboardControlsName}" />
                <Run Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="{x:Static props:Resources.KeyboardControlsDescriptionCanvas}" />
            </TextBlock>
        </StackPanel>
        <Rectangle
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            Fill="{DynamicResource CardStrokeColorDefaultBrush}" />
        <Grid Grid.Row="2" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                Click="OnCancel"
                Content="{x:Static props:Resources.Cancel}"
                TabIndex="2" />
            <Button
                HorizontalAlignment="Stretch"
                Click="OnSave"
                Content="{x:Static props:Resources.Save}"
                Style="{StaticResource AccentButtonStyle}"
                TabIndex="1" />
        </Grid>
    </Grid>
</local:EditorWindow>