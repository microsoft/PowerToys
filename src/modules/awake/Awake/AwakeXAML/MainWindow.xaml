<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="Awake.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedVisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:vm="using:Awake.ViewModels"
    xmlns:winuiex="using:WinUIEx"
    MinWidth="0"
    MinHeight="0"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    IsTitleBarVisible="False">
    <winuiex:WindowEx.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </winuiex:WindowEx.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        IsTabStop="True"
        KeyDown="RootGrid_KeyDown"
        TabFocusNavigation="Local">
        <Grid.Resources>
            <Style
                x:Key="FlyoutIconButtonStyle"
                BasedOn="{StaticResource SubtleButtonStyle}"
                TargetType="Button">
                <Setter Property="Padding" Value="6" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
            </Style>
        </Grid.Resources>
        <Border x:Name="MainContainer">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="48" />
                </Grid.RowDefinitions>

                <StackPanel
                    Grid.Row="0"
                    Padding="16,16,16,16"
                    Spacing="12">

                    <StackPanel Spacing="2">
                        <TextBlock
                            x:Name="TitleText"
                            FontWeight="SemiBold"
                            Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            x:Name="StatusText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="ModeHeaderText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            x:Name="ModeComboBox"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="ModeComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="ModeOffItem" />
                            <ComboBoxItem x:Name="ModeIndefiniteItem" />
                            <ComboBoxItem x:Name="ModeTimedItem" />
                            <ComboBoxItem x:Name="ModeExpirableItem" />
                        </ComboBox>
                    </StackPanel>

                    <ToggleSwitch
                        x:Name="KeepDisplayOnToggle"
                        IsEnabled="{x:Bind ViewModel.KeepDisplayOnEnabled, Mode=OneWay}"
                        IsOn="{x:Bind ViewModel.KeepDisplayOn, Mode=TwoWay}" />

                    <StackPanel
                        x:Name="TimedSection"
                        Spacing="4"
                        Visibility="{x:Bind ViewModel.TimedSectionVisibility, Mode=OneWay}">
                        <TextBlock
                            x:Name="TimedHeaderText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ItemsControl x:Name="TimedPresetsItemsControl" ItemsSource="{x:Bind ViewModel.TimedPresets, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TimedPreset">
                                    <RadioButton
                                        Margin="0,2"
                                        HorizontalAlignment="Stretch"
                                        Checked="TimedPresetRadio_Checked"
                                        Content="{x:Bind Label}"
                                        GroupName="AwakeTimedPresets"
                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                        Tag="{x:Bind}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <HyperlinkButton
                            x:Name="EditPresetsLink"
                            Margin="-12,0,0,0"
                            Click="OnOpenSettingsClick" />
                    </StackPanel>

                    <StackPanel
                        x:Name="ExpirableSection"
                        Spacing="4"
                        Visibility="{x:Bind ViewModel.ExpirableSectionVisibility, Mode=OneWay}">
                        <TextBlock
                            x:Name="ExpirableHeaderText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid ColumnSpacing="8" RowSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CalendarDatePicker
                                x:Name="ExpirationDatePicker"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                Date="{x:Bind ViewModel.ExpirationDate, Mode=TwoWay}" />
                            <TimePicker
                                x:Name="ExpirationTimePicker"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                MinuteIncrement="5"
                                SelectedTime="{x:Bind ViewModel.ExpirationTime, Mode=TwoWay}" />
                        </Grid>
                        <Button
                            x:Name="ApplyExpirableButton"
                            HorizontalAlignment="Right"
                            Click="OnApplyExpirableClick"
                            Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </StackPanel>

                <Grid
                    Grid.Row="1"
                    Padding="8,0,12,0"
                    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0">
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="ExitButton"
                            Click="OnExitClick"
                            Content="{ui:FontIcon Glyph=&#xE7E8;,
                                                  FontSize=16}"
                            Style="{StaticResource FlyoutIconButtonStyle}"
                            Visibility="{x:Bind ViewModel.ExitButtonVisibility, Mode=OneTime}">
                            <ToolTipService.ToolTip>
                                <TextBlock x:Name="ExitButtonTooltip" />
                            </ToolTipService.ToolTip>
                        </Button>
                        <Button
                            x:Name="OpenSettingsButton"
                            Click="OnOpenSettingsClick"
                            Style="{StaticResource FlyoutIconButtonStyle}">
                            <ToolTipService.ToolTip>
                                <TextBlock x:Name="OpenSettingsButtonTooltip" />
                            </ToolTipService.ToolTip>
                            <AnimatedIcon x:Name="SettingsAnimatedIcon">
                                <AnimatedIcon.Source>
                                    <animatedVisuals:AnimatedSettingsVisualSource />
                                </AnimatedIcon.Source>
                                <AnimatedIcon.FallbackIconSource>
                                    <SymbolIconSource Symbol="Setting" />
                                </AnimatedIcon.FallbackIconSource>
                            </AnimatedIcon>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</winuiex:WindowEx>

