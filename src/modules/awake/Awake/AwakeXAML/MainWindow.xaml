<?xml version="1.0" encoding="utf-8" ?>
<winuiex:WindowEx
    x:Class="Awake.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animatedVisuals="using:Microsoft.UI.Xaml.Controls.AnimatedVisuals"
    xmlns:ui="using:CommunityToolkit.WinUI"
    xmlns:winuiex="using:WinUIEx"
    Width="320"
    Height="460"
    MinWidth="320"
    MinHeight="460"
    IsMaximizable="False"
    IsMinimizable="False"
    IsResizable="False"
    IsTitleBarVisible="False">
    <winuiex:WindowEx.Backdrop>
        <winuiex:AcrylicSystemBackdrop
            DarkFallbackColor="#1c1c1c"
            DarkLuminosityOpacity="0.96"
            DarkTintColor="#202020"
            DarkTintOpacity="0.5"
            LightFallbackColor="#EEEEEE"
            LightLuminosityOpacity="0.90"
            LightTintColor="#F3F3F3"
            LightTintOpacity="0" />
    </winuiex:WindowEx.Backdrop>

    <Grid
        x:Name="RootGrid"
        IsTabStop="True"
        KeyDown="RootGrid_KeyDown"
        TabFocusNavigation="Local">
        <Grid.Resources>
            <Style
                x:Key="FlyoutIconButtonStyle"
                BasedOn="{StaticResource SubtleButtonStyle}"
                TargetType="Button">
                <Setter Property="Padding" Value="6" />
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="48" />
        </Grid.RowDefinitions>

        <Grid
            Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <ScrollViewer
                Grid.Row="0"
                HorizontalScrollMode="Disabled"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Auto">
                <StackPanel Padding="16,16,16,16" Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Image
                            x:Name="StatusIcon"
                            Width="16"
                            Height="16" />
                        <TextBlock
                            x:Name="StatusText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            x:Name="ModeHeaderText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <ComboBox
                            x:Name="ModeComboBox"
                            HorizontalAlignment="Stretch"
                            SelectionChanged="ModeComboBox_SelectionChanged">
                            <ComboBoxItem x:Name="ModeOffItem" />
                            <ComboBoxItem x:Name="ModeIndefiniteItem" />
                            <ComboBoxItem x:Name="ModeTimedItem" />
                            <ComboBoxItem x:Name="ModeExpirableItem" />
                        </ComboBox>
                    </StackPanel>

                    <CheckBox
                        x:Name="KeepDisplayOnCheckBox"
                        IsChecked="{x:Bind ViewModel.KeepDisplayOn, Mode=TwoWay}"
                        IsEnabled="{x:Bind ViewModel.KeepDisplayOnEnabled, Mode=OneWay}" />

                    <StackPanel
                        x:Name="TimedSection"
                        Spacing="4"
                        Visibility="{x:Bind ViewModel.TimedSectionVisibility, Mode=OneWay}">
                        <TextBlock
                            x:Name="TimedHeaderText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <NumberBox
                                x:Name="IntervalHoursInput"
                                Width="120"
                                LargeChange="5"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.IntervalHours, Mode=TwoWay}" />
                            <NumberBox
                                x:Name="IntervalMinutesInput"
                                Width="120"
                                LargeChange="5"
                                Maximum="60"
                                Minimum="0"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact"
                                Value="{x:Bind ViewModel.IntervalMinutes, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel
                        x:Name="ExpirableSection"
                        Spacing="4"
                        Visibility="{x:Bind ViewModel.ExpirableSectionVisibility, Mode=OneWay}">
                        <TextBlock
                            x:Name="ExpirableHeaderText"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Spacing="8">
                            <DatePicker
                                x:Name="ExpirationDatePicker"
                                HorizontalAlignment="Stretch"
                                Date="{x:Bind ViewModel.ExpirationDate, Mode=TwoWay}" />
                            <TimePicker
                                x:Name="ExpirationTimePicker"
                                HorizontalAlignment="Stretch"
                                ClockIdentifier="24HourClock"
                                MinuteIncrement="5"
                                Time="{x:Bind ViewModel.ExpirationTime, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <Grid Grid.Row="1">
            <StackPanel
                Grid.Row="1"
                Margin="0,0,12,0"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    x:Name="ExitButton"
                    Click="OnExitClick"
                    Content="{ui:FontIcon Glyph=&#xE7E8;,
                                          FontSize=16}"
                    Style="{StaticResource FlyoutIconButtonStyle}"
                    Visibility="{x:Bind ViewModel.ExitButtonVisibility, Mode=OneTime}">
                    <ToolTipService.ToolTip>
                        <TextBlock x:Name="ExitButtonTooltip" />
                    </ToolTipService.ToolTip>
                </Button>
                <Button
                    x:Name="OpenSettingsButton"
                    Click="OnOpenSettingsClick"
                    Style="{StaticResource FlyoutIconButtonStyle}">
                    <ToolTipService.ToolTip>
                        <TextBlock x:Name="OpenSettingsButtonTooltip" />
                    </ToolTipService.ToolTip>
                    <AnimatedIcon x:Name="SettingsAnimatedIcon">
                        <AnimatedIcon.Source>
                            <animatedVisuals:AnimatedSettingsVisualSource />
                        </AnimatedIcon.Source>
                        <AnimatedIcon.FallbackIconSource>
                            <SymbolIconSource Symbol="Setting" />
                        </AnimatedIcon.FallbackIconSource>
                    </AnimatedIcon>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</winuiex:WindowEx>

