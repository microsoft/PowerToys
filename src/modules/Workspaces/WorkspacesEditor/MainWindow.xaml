<Window
    x:Class="WorkspacesEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:props="clr-namespace:WorkspacesEditor.Properties"
    x:Name="WorkspacesMainWindow"
    Title="{x:Static props:Resources.MainTitle}"
    MinWidth="750"
    MinHeight="680"
    AutomationProperties.Name="Workspaces Editor"
    Closing="OnClosing"
    ContentRendered="OnContentRendered"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid Margin="0,16,0,0">
        <Grid.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </Grid.Resources>
        <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" />

        <!-- Transient, non-blocking status shown while first-run service
             provisioning (UAC + MSIX deploy) runs in the background.  The editor
             stays fully interactive; this only tells the user setup is underway so
             an initially-empty list doesn't look like data loss. -->
        <Border
            Margin="0,0,0,20"
            Padding="14,8"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Background="#DD2B2B2B"
            CornerRadius="14"
            Visibility="{Binding MainViewModel.IsProvisioning, ElementName=WorkspacesMainWindow, Converter={StaticResource BoolToVis}}">
            <TextBlock
                Foreground="White"
                Text="{x:Static props:Resources.Provisioning_Status}" />
        </Border>
    </Grid>
</Window>
