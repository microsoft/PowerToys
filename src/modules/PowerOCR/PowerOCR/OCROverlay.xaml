<Window
    x:Class="PowerOCR.OCROverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="TextExtractor">

    <Grid x:Name="RootGrid">
        <Viewbox>
            <Image x:Name="BackgroundImage" Stretch="UniformToFill" />
        </Viewbox>
        <Path
            x:Name="DarkOverlayPath"
            IsHitTestVisible="False"
            Opacity="0">
            <Path.Fill>
                <SolidColorBrush Color="Black" />
            </Path.Fill>
            <Path.Data>
                <GeometryGroup FillRule="EvenOdd">
                    <RectangleGeometry x:Name="FullWindow" />
                    <RectangleGeometry x:Name="clippingGeometry" />
                </GeometryGroup>
            </Path.Data>
        </Path>
        <Canvas
            Name="RegionClickCanvas"
            Background="Transparent"
            PointerPressed="RegionClickCanvas_PointerPressed"
            PointerMoved="RegionClickCanvas_PointerMoved"
            PointerReleased="RegionClickCanvas_PointerReleased">
        </Canvas>
        <Border
            x:Name="TopButtonsStackPanel"
            Margin="12"
            Padding="4,8,4,8"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <ComboBox
                    x:Name="LanguagesComboBox"
                    Margin="4,0"
                    SelectionChanged="LanguagesComboBox_SelectionChanged" />
                <ToggleButton
                    x:Name="SingleLineToggleButton"
                    Width="32" Height="32" Margin="4,0" Padding="0"
                    Click="SingleLineMenuItem_Click">
                    <TextBlock FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" Text="&#xF16E;" />
                </ToggleButton>
                <ToggleButton
                    x:Name="TableToggleButton"
                    Width="32" Height="32" Margin="4,0" Padding="0"
                    Click="TableToggleButton_Click">
                    <TextBlock FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" Text="&#xE80A;" />
                </ToggleButton>
                <Button
                    x:Name="SettingsButton"
                    Width="32" Height="32" Margin="4,0" Padding="0"
                    Click="SettingsMenuItem_Click">
                    <TextBlock FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" Text="&#xE713;" />
                </Button>
                <Button
                    x:Name="CancelButton"
                    Width="32" Height="32" Margin="4,0" Padding="0"
                    Click="CancelMenuItem_Click">
                    <TextBlock FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="16" Text="&#xE711;" />
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
