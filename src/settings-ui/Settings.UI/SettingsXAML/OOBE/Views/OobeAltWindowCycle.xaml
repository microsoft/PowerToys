<Page
    x:Class="Microsoft.PowerToys.Settings.UI.OOBE.Views.OobeAltWindowCycle"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.PowerToys.Settings.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ptcontrols="using:Microsoft.PowerToys.Common.UI.Controls"
    xmlns:tkcontrols="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <controls:OOBEPageControl
        x:Uid="Oobe_AltWindowCycle"
        HeroImage="ms-appx:///Assets/Settings/Modules/OOBE/WindowHopper.png"
        HeroImageHeight="192">
        <controls:OOBEPageControl.PageContent>
            <StackPanel Orientation="Vertical" Spacing="12">
                <TextBlock x:Uid="Oobe_HowToUse" Style="{ThemeResource OobeSubtitleStyle}" />

                <ptcontrols:ShortcutWithTextLabelControl x:Name="NextWindowHotkeyControl" x:Uid="Oobe_AltWindowCycle_HowToUse_Next" />
                <ptcontrols:ShortcutWithTextLabelControl x:Name="PreviousWindowHotkeyControl" x:Uid="Oobe_AltWindowCycle_HowToUse_Previous" />

                <TextBlock x:Uid="Oobe_TipsAndTricks" Style="{ThemeResource OobeSubtitleStyle}" />

                <tkcontrols:MarkdownTextBlock x:Uid="Oobe_AltWindowCycle_TipsAndTricks" />

                <Button
                    x:Uid="OOBE_Settings"
                    AutomationProperties.AutomationId="AltWindowCycleOpenSettingsButton"
                    Click="SettingsLaunchButton_Click" />
            </StackPanel>
        </controls:OOBEPageControl.PageContent>
    </controls:OOBEPageControl>
</Page>
