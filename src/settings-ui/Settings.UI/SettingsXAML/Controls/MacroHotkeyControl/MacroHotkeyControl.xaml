<UserControl
    x:Class="Microsoft.PowerToys.Settings.UI.Controls.MacroHotkeyControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.PowerToys.Settings.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Button
        x:Name="RecordButton"
        MinWidth="160"
        Content="{x:Bind HotkeyDisplayText, Mode=OneWay}"
        Click="RecordButton_Click">
        <Button.Flyout>
            <Flyout
                x:Name="RecorderFlyout"
                Placement="Bottom"
                Closed="RecorderFlyout_Closed">
                <StackPanel Spacing="12" Padding="4">
                    <TextBlock
                        Text="Press the desired key combination, then click Save."
                        TextWrapping="Wrap"
                        MaxWidth="280"
                        Style="{StaticResource CaptionTextBlockStyle}" />
                    <controls:ShortcutDialogContentControl x:Name="KeysDisplay" />
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button
                            x:Name="SaveButton"
                            Content="Save"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="SaveButton_Click" />
                        <Button
                            x:Name="ClearButton"
                            Content="Clear"
                            Click="ClearButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
