<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="NewInfoBadge" TargetType="InfoBadge">
        <Setter Property="Padding" Value="5,1,5,2" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="InfoBadge">
                    <Border
                        x:Name="RootGrid"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.InfoBadgeCornerRadius}">
                        <TextBlock
                            x:Uid="SettingsPage_NewInfoBadge"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="10" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="UpdateInfoBadgeStyle" TargetType="InfoBadge">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Background" Value="#F09A2A" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="InfoBadge">
                    <Border
                        x:Name="RootGrid"
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.InfoBadgeCornerRadius}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>