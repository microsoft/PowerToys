<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Globals">
    <ProjectGuid>{8A7FB7FA-65EA-4004-BA73-1B237435A57B}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>PowerToysCliShim</RootNamespace>
    <ProjectName>PowerToys.CliShim</ProjectName>
    <UsePrecompiledHeaders>false</UsePrecompiledHeaders>
    <OutDir>$(RepoRoot)$(Platform)\$(Configuration)\CliShim\</OutDir>
    <TargetName>PowerToys.CliShim</TargetName>
  </PropertyGroup>
  <PropertyGroup Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <Import Project="CliShimManifest.props" />

  <PropertyGroup>
    <VcpkgEnabled>false</VcpkgEnabled>
    <VcpkgManifestEnabled>false</VcpkgManifestEnabled>
    <CliStageDir>$(RepoRoot)$(Platform)\$(Configuration)\cli\</CliStageDir>
  </PropertyGroup>
  <ItemDefinitionGroup>
    <ClCompile>
      <PrecompiledHeader>NotUsing</PrecompiledHeader>
      <AdditionalIncludeDirectories>$(IntDir);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
    <ResourceCompile>
      <PreprocessorDefinitions>VERSION_MAJOR=$(Version.Split('.')[0]);VERSION_MINOR=$(Version.Split('.')[1]);VERSION_REVISION=$(Version.Split('.')[2]);%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ResourceCompile>
    <Link>
      <SubSystem>Console</SubSystem>
    </Link>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="main.cpp" />
    <ClCompile Include="CommandLine.cpp" />
    <ClInclude Include="CommandLine.h" />
    <ResourceCompile Include="CliShim.rc" />
    <None Include="CliShimManifest.props" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />

  <Target Name="GenerateCliShimTargets" BeforeTargets="ClCompile">
    <ItemGroup>
      <_CliShimTargetLine Include="{ L%22%(CliShim.Identity)%22, L%22%(CliShim.RelativeTarget)%22 }," />
    </ItemGroup>
    <MakeDir Directories="$(IntDir)" />
    <WriteLinesToFile File="$(IntDir)CliShimTargets.g.inc"
                      Lines="@(_CliShimTargetLine)"
                      Overwrite="true"
                      WriteOnlyWhenDifferent="true" />
  </Target>

  <!-- Keep explicit WiX components synchronized with the shared manifest. -->
  <Target Name="ValidateCliShimInstallerManifest" BeforeTargets="ClCompile">
    <PropertyGroup>
      <_CliShimWxsText>$([System.IO.File]::ReadAllText('$(RepoRoot)installer\PowerToysSetupVNext\CliShims.wxs'))</_CliShimWxsText>
      <_CliShimWxsCount>$([System.Text.RegularExpressions.Regex]::Matches('$(_CliShimWxsText)', 'cli\\[^&quot;\\]+\.exe').Count)</_CliShimWxsCount>
      <_CliShimManifestCount>@(CliShim-&gt;Count())</_CliShimManifestCount>
    </PropertyGroup>
    <ItemGroup>
      <CliShim>
        <InWxs>$(_CliShimWxsText.Contains('cli\%(Identity).exe'))</InWxs>
      </CliShim>
    </ItemGroup>
    <Error Condition="'%(CliShim.InWxs)' != 'True'"
           Text="CliShim installer drift: command '%(CliShim.Identity)' is missing from CliShims.wxs." />
    <Error Condition="'$(_CliShimWxsCount)' != '$(_CliShimManifestCount)'"
           Text="CliShim installer drift: CliShims.wxs contains $(_CliShimWxsCount) command executables, but CliShimManifest.props defines $(_CliShimManifestCount)." />
  </Target>

  <Target Name="StageCliShims" AfterTargets="Build">
    <ItemGroup>
      <_ExistingCliShim Include="$(CliStageDir)*.exe" />
    </ItemGroup>
    <Delete Files="@(_ExistingCliShim)" />
    <MakeDir Directories="$(CliStageDir)" />
    <Copy SourceFiles="@(CliShim->'$(TargetPath)')"
          DestinationFiles="@(CliShim->'$(CliStageDir)%(Identity).exe')" />
  </Target>
</Project>
